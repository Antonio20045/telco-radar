<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Telco Radar – Global Competitive Intelligence</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <header class="site">
    <div class="wrap">
      <h1><a href="index.html">Telco <span>Radar</span></a></h1>
      <p>Wöchentliches Competitive-Intelligence-Briefing: Telcos weltweit – nur was neu ist.</p>
    </div>
  </header>
  <main>
    <div class="wrap">
      {% if latest %}
      <article class="report">
        {{ body | safe }}
      </article>
      {% else %}
      <article class="report">
        <h1>Noch kein Bericht</h1>
        <p>Der erste Lauf der Pipeline erzeugt hier das aktuelle Briefing.</p>
      </article>
      {% endif %}
      <nav class="archive">
        <h2>Archiv</h2>
        <ul>
          {% for entry in archive %}
          <li><a href="{{ entry.href }}" {% if loop.first %}class="current"{% endif %}>{{ entry.date }}</a></li>
          {% endfor %}
        </ul>
      </nav>
    </div>
  </main>
  <footer class="site">Telco Radar · automatisiert erstellt · nur für interne Zwecke</footer>
</body>
</html>
