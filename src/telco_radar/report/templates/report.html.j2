{% extends "base.html.j2" %}
{% set active = 'dashboard' if is_latest else 'archive' %}
{% block title %}Telco Radar - Bericht {{ report.date if report else '' }}{% endblock %}

{% macro darr(d) %}<span class="d {{ d.dir }}">{% if d.dir == 'up' %}&#9650;{{ d.abs }}{% elif d.dir == 'down' %}&#9660;{{ d.abs }}{% else %}&middot;{% endif %}</span>{% endmacro %}

{% block content %}
{% if report %}

<section class="hero">
  <h1>{{ date_de }}</h1>
  <p class="hero-lead">Wettbewerbs-Monitoring &middot; {{ report.stats.get('operators', num_operators or '–') }} Netzbetreiber beobachtet &middot; {{ report.stats.get('collected', '–') }} Artikel geprüft</p>
  {% if dash %}
  <div class="kpis">
    {% for k in dash.kpis %}
    <div class="kpi{% if k.accent %} accent{% endif %}">
      <b{% if k.text %} class="kpi-text"{% endif %}>{{ k.num }}</b>
      <span>{{ k.label }}</span>
    </div>
    {% endfor %}
  </div>
  {% endif %}
  <details class="explainer">
    <summary>Wie entsteht dieser Bericht? <span class="hint">Kurz erklärt</span></summary>
    <div class="explainer-body">
      <p><b>Sammeln.</b> Jede Woche werden die offiziellen Presseseiten von {{ report.stats.get('operators', num_operators or '80') }} Netzbetreibern und die Telco-Fachpresse ausgewertet. Jede Quelle ist verlinkt und nachprüfbar.</p>
      <p><b>Nur Neues.</b> Was schon berichtet wurde, wird aussortiert. Hier steht nur, was seit dem letzten Bericht dazugekommen ist.</p>
      <p><b>Bewerten.</b> Jede Meldung wird eingeordnet: Was ist passiert, was kann Vodafone daraus machen? Dringlichkeit 1–5. Details im <a href="{{ prefix }}protokoll.html">Protokoll</a>.</p>
    </div>
  </details>
</section>

{% if top_priorities %}
<section class="section" id="prioritaet">
  <div class="section-head"><h2><span class="sec-no">01</span> In 60 Sekunden</h2>
    <p class="section-title">Das sollte Vodafone jetzt wissen</p></div>
  <div class="prio-list">
    {% for h in top_priorities[:3] %}
    <article class="prio-card{% if loop.first %} lead{% endif %}">
      <div class="prio-top">
        <span class="rel-badge r{{ h.relevance }}">{{ h.relevance }}/5 &middot; {{ h.relevance_label }}</span>
        <span class="chip">{{ h.category }}</span>
      </div>
      <h3><a href="{{ h.url }}" target="_blank" rel="noopener">{{ h.title }}</a></h3>
      <p class="prio-meta"><b>{{ h.operator or h.source_label }}</b><span class="sep"></span>{{ h.region }}{% if h.date %}<span class="sep"></span>{{ h.date }}{% endif %}</p>
      {% if h.why_it_matters %}<p class="why"><span class="why-label">Für Vodafone</span>{{ h.why_it_matters }}</p>
      {% elif h.summary %}<p class="prio-summary">{{ h.summary }}</p>{% endif %}
      <a class="source-link" href="{{ h.url }}" target="_blank" rel="noopener">Quelle: {{ h.source_label }} &nearr;</a>
    </article>
    {% endfor %}
  </div>
</section>
{% endif %}

{% if dash %}
<section class="section" id="zahlen">
  <div class="section-head"><h2><span class="sec-no">02</span> Zahlen &amp; Insights</h2>
    <p class="section-title">Die Woche in Kennzahlen</p></div>
  <div class="chart-grid two">
    <div class="panel">
      <h3 class="panel-title">Share of Voice</h3>
      <p class="panel-note">Wer diese Woche die relevante Presse dominiert &middot; Δ zur Vorwoche.</p>
      <div class="bars">
        {% for s in dash.sov %}
        <div class="bar-row">
          <span class="bar-lab" title="{{ s.op }}">{{ s.op }}</span>
          <span class="bar-track"><span class="bar-fill" style="width:{{ s.w }}%"></span></span>
          <span class="bar-val">{{ s.n }} {{ darr(s.delta) }}</span>
        </div>
        {% endfor %}
      </div>
    </div>
    <div class="panel">
      <h3 class="panel-title">Themen-Momentum</h3>
      <p class="panel-note">Worauf sich die Branche verlagert &middot; Δ zur Vorwoche.</p>
      <div class="bars">
        {% for m in dash.momentum %}
        <div class="bar-row">
          <span class="bar-lab" title="{{ m.cat }}">{{ m.cat }}</span>
          <span class="bar-track"><span class="bar-fill" style="width:{{ m.w }}%;background:{{ m.color }}"></span></span>
          <span class="bar-val">{{ m.n }} {{ darr(m.delta) }}</span>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>

  {% if dash.competitors %}
  <div class="panel wide scoreboard">
    <h3 class="panel-title">Fokus-Wettbewerber</h3>
    <p class="panel-note">Aktivität und eine Einordnung je Wettbewerber diese Woche.</p>
    {% for c in dash.competitors %}
    <div class="score-row">
      <div class="score-head"><span class="score-name">{{ c.name }}</span><span class="score-n">{{ c.n }} Meldungen</span></div>
      <span class="bar-track"><span class="bar-fill" style="width:{{ c.w }}%"></span></span>
      {% if c.impl %}<p class="score-impl"><span class="why-label">Für Vodafone</span>{{ c.impl }}</p>{% endif %}
    </div>
    {% endfor %}
    {% if n_competitors %}<p class="section-more"><a href="{{ prefix }}wettbewerber.html">Detailanalyse der Wettbewerber &nearr;</a></p>{% endif %}
  </div>
  {% endif %}

  {% if dash.trend.n > 1 %}
  <div class="panel wide">
    <h3 class="panel-title">Historische Trends</h3>
    <p class="panel-note">Verlauf über die letzten {{ dash.trend.n }} Berichte &middot; {{ dash.trend.weeks | first }} bis {{ dash.trend.weeks | last }}.</p>
    <div class="trend-grid">
      <div class="trend-cell">
        <div class="trend-top"><span class="trend-name">Neue Meldungen / Woche</span><span class="trend-val">{{ dash.trend.volume_last }} {{ darr(dash.trend.volume_delta) }}</span></div>
        {{ dash.trend.volume_spark | safe }}
      </div>
      {% for c in dash.trend.competitors %}
      <div class="trend-cell">
        <div class="trend-top"><span class="trend-name">{{ c.name }}</span><span class="trend-val">{{ c.last }} {{ darr(c.delta) }}</span></div>
        {{ c.spark | safe }}
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}
</section>
{% endif %}

{% if briefing_html %}
<section class="section" id="bericht">
  <div class="section-head"><h2><span class="sec-no">03</span> Wochenbericht</h2>
    <p class="section-title">Einordnung und Handlungsempfehlungen</p></div>
  <article class="prose">{{ briefing_html | safe }}</article>
</section>
{% endif %}

{% if highlights %}
<section class="section" id="explorer">
  <div class="section-head"><h2><span class="sec-no">04</span> Alle Meldungen</h2>
    <p class="section-title">Suchen, filtern, im Detail lesen</p></div>
  <div class="filters">
    <input type="search" id="f-search" placeholder="Suchen: Operator, Thema, Stichwort …" aria-label="Suche">
    <select id="f-region" aria-label="Region"><option value="">Alle Regionen</option>{% for r in regions %}<option value="{{ r }}">{{ r }}</option>{% endfor %}</select>
    <select id="f-category" aria-label="Thema"><option value="">Alle Themen</option>{% for c in categories %}<option value="{{ c }}">{{ c }}</option>{% endfor %}</select>
    <select id="f-relevance" aria-label="Dringlichkeit"><option value="">Jede Dringlichkeit</option><option value="5">5/5 sofort</option><option value="4">ab 4/5</option><option value="3">ab 3/5</option></select>
    <select id="f-sort" aria-label="Sortierung"><option value="relevance">Dringlichste zuerst</option><option value="date">Neueste zuerst</option><option value="operator">Operator (A–Z)</option></select>
  </div>
  <div class="explorer" id="explorer-app">
    <div class="ex-list" id="ex-list" role="listbox" aria-label="Meldungsliste"></div>
    <div class="ex-detail" id="ex-detail"><p class="ex-detail-empty">Meldung links auswählen.</p></div>
  </div>
  <p class="ex-count" id="ex-count"></p>
  <script type="application/json" id="explorer-data">{{ explorer_json | safe }}</script>
</section>
{% endif %}

{% else %}
<section class="hero"><h1>Noch kein Bericht</h1></section>
{% endif %}

{% if archive and archive | length > 1 %}
<section class="section" id="archiv">
  <div class="section-head"><h2><span class="sec-no">05</span> Frühere Berichte</h2></div>
  <div class="pill-row">
    {% for entry in archive %}<a class="pill-link {% if report and entry.date == report.date %}current{% endif %}" href="{{ prefix }}reports/{{ entry.date }}.html">{{ entry.date_de }}</a>{% endfor %}
  </div>
</section>
{% endif %}
{% endblock %}
