{% extends "base.html.j2" %}
{% set active = 'dashboard' if is_latest else 'archive' %}
{% block title %}Telco Radar - Bericht {{ report.date if report else '' }}{% endblock %}

{% block content %}
{% if report %}

<section class="hero compact">
  <div class="hero-row">
    <h1>{{ date_de }}</h1>
    <div class="kpis inline">
      <div class="kpi"><span class="kpi-num">{{ report.stats.get('operators', num_operators or '–') }}</span><span class="kpi-label">Betreiber</span></div>
      <div class="kpi"><span class="kpi-num">{{ report.stats.get('collected', '–') }}</span><span class="kpi-label">Meldungen geprüft</span></div>
      <div class="kpi accent"><span class="kpi-num">{{ report.stats.get('new', '–') }}</span><span class="kpi-label">neu diese Woche</span></div>
    </div>
  </div>
  <details class="explainer">
    <summary>Wie entsteht dieser Bericht? <span class="hint">Kurz erklärt</span></summary>
    <div class="explainer-body">
      <p><b>Sammeln.</b> Jede Woche werden die internationale Telco-Fachpresse und eine laufende Nachrichten-Suche zu {{ num_operators or 80 }} Netzbetreibern ausgewertet.</p>
      <p><b>Nur Neues.</b> Was schon berichtet wurde, wird aussortiert. Hier steht nur, was seit dem letzten Bericht dazugekommen ist.</p>
      <p><b>Bewerten.</b> Jede Meldung wird eingeordnet: Was ist passiert, was kann Vodafone daraus machen? Dringlichkeit 1–5
        <span class="legend"><i class="ldot r5"></i>5 sofort</span><span class="legend"><i class="ldot r4"></i>4 wichtig</span><span class="legend"><i class="ldot r3"></i>3 beobachten</span>.</p>
      <p><b>Nachprüfbar.</b> Jede Aussage verlinkt direkt auf den Originalartikel. Details im <a href="{{ prefix }}protokoll.html">Protokoll</a>.</p>
    </div>
  </details>
</section>

<nav class="pagenav">
  {% if top_priorities %}<a href="#prioritaet">Prioritäten</a>{% endif %}
  {% if briefing_html %}<a href="#bericht">Wochenbericht</a>{% endif %}
  {% if charts %}<a href="#zahlen">Zahlen</a>{% endif %}
  {% if n_competitors %}<a href="{{ prefix }}wettbewerber.html">Wettbewerber &nearr;</a>{% endif %}
  {% if highlights %}<a href="#explorer">Alle Meldungen</a>{% endif %}
</nav>

{% if top_priorities %}
<section class="section" id="prioritaet">
  <div class="section-head"><h2><span class="sec-no">01</span> Priorität</h2>
    <p class="section-title">Das sollte Vodafone diese Woche wissen</p></div>
  <div class="prio-grid">
    {% for h in top_priorities %}
    <article class="prio-card{% if loop.first %} lead{% endif %}">
      <div class="prio-top">
        <span class="rel-badge r{{ h.relevance }}">{{ h.relevance }}/5 · {{ h.relevance_label }}</span>
        <span class="chip">{{ h.category }}</span>
      </div>
      <h3><a href="{{ h.url }}" target="_blank" rel="noopener">{{ h.title }}</a></h3>
      <p class="prio-meta"><b>{{ h.operator or h.source_label }}</b><span class="sep"></span>{{ h.region }}{% if h.date %}<span class="sep"></span>{{ h.date }}{% endif %}</p>
      {% if h.summary %}<p class="prio-summary">{{ h.summary }}</p>{% endif %}
      {% if h.why_it_matters %}<p class="why"><span class="why-label">Warum das zählt</span>{{ h.why_it_matters }}</p>{% endif %}
      <a class="source-link" href="{{ h.url }}" target="_blank" rel="noopener">Quelle: {{ h.source_label }} &nearr;</a>
    </article>
    {% endfor %}
  </div>
</section>
{% endif %}

{% if briefing_html %}
<section class="section" id="bericht">
  <div class="section-head"><h2><span class="sec-no">02</span> Wochenbericht</h2>
    <p class="section-title">Einordnung und Handlungsempfehlungen</p></div>
  <article class="prose">{{ briefing_html | safe }}</article>
</section>
{% endif %}

{% if charts %}
<section class="section" id="zahlen">
  <div class="section-head"><h2><span class="sec-no">03</span> Die Woche in Zahlen</h2>
    <p class="section-title">Wer bewegt sich, worum geht es</p></div>
  <div class="chart-grid two">
    <div class="panel">
      <h3 class="panel-title">Aktivste Wettbewerber</h3>
      <p class="panel-note">Wer diese Woche die meisten relevanten Meldungen produziert hat.</p>
      {{ charts.competitors | safe }}
    </div>
    <div class="panel">
      <h3 class="panel-title">Themen-Schwerpunkte</h3>
      <p class="panel-note">Worum es bei den relevanten Meldungen geht.</p>
      {{ charts.categories | safe }}
    </div>
  </div>
  {% if n_competitors %}<p class="section-more"><a href="{{ prefix }}wettbewerber.html">Detailanalyse der wichtigsten Wettbewerber &nearr;</a></p>{% endif %}
</section>
{% endif %}

{% if highlights %}
<section class="section" id="explorer">
  <div class="section-head"><h2><span class="sec-no">04</span> Alle Meldungen</h2>
    <p class="section-title">Suchen, filtern, im Detail lesen</p></div>
  <div class="filters">
    <input type="search" id="f-search" placeholder="Suchen: Operator, Thema, Stichwort …" aria-label="Suche">
    <select id="f-region" aria-label="Region"><option value="">Alle Regionen</option>{% for r in regions %}<option value="{{ r }}">{{ r }}</option>{% endfor %}</select>
    <select id="f-category" aria-label="Thema"><option value="">Alle Themen</option>{% for c in categories %}<option value="{{ c }}">{{ c }}</option>{% endfor %}</select>
    <select id="f-relevance" aria-label="Dringlichkeit"><option value="">Jede Dringlichkeit</option><option value="5">5/5 sofort</option><option value="4">ab 4/5</option><option value="3">ab 3/5</option></select>
    <select id="f-sort" aria-label="Sortierung"><option value="relevance">Dringlichste zuerst</option><option value="date">Neueste zuerst</option><option value="operator">Operator (A–Z)</option></select>
  </div>
  <div class="explorer" id="explorer-app">
    <div class="ex-list" id="ex-list" role="listbox" aria-label="Meldungsliste"></div>
    <div class="ex-detail" id="ex-detail"><p class="ex-detail-empty">Meldung links auswählen.</p></div>
  </div>
  <p class="ex-count" id="ex-count"></p>
  <script type="application/json" id="explorer-data">{{ explorer_json | safe }}</script>
</section>
{% endif %}

{% else %}
<section class="hero"><h1>Noch kein Bericht</h1></section>
{% endif %}

{% if archive and archive | length > 1 %}
<section class="section" id="archiv">
  <div class="section-head"><h2><span class="sec-no">05</span> Frühere Berichte</h2></div>
  <div class="pill-row">
    {% for entry in archive %}<a class="pill-link {% if report and entry.date == report.date %}current{% endif %}" href="{{ prefix }}reports/{{ entry.date }}.html">{{ entry.date_de }}</a>{% endfor %}
  </div>
</section>
{% endif %}
{% endblock %}
