{% extends "base.html.j2" %}
{% set active = 'bericht' %}
{% block title %}Marktrecherche · Bericht {{ report.date if report else '' }}{% endblock %}

{% block content %}
{% if report %}

<section class="page-hero">
  <div class="page-hero-row">
    <div>
      <p class="page-kicker">Wöchentlicher Wettbewerbsbericht</p>
      <h1>Was Vodafone jetzt<br>wissen muss.</h1>
    </div>
    <span class="page-date">{{ date_de }}</span>
  </div>
  <p class="page-lead">Die relevanten Wettbewerbszüge dieser Woche – verdichtet auf Entscheidungen, nicht auf Quellen.</p>
  <p class="br-method"><a href="{{ prefix }}protokoll.html">Methode und Quellenbasis ansehen &nearr;</a></p>
</section>

{% if top_priorities %}
<section class="section" id="prioritaet">
  <div class="section-head"><h2><span class="sec-no">01</span></h2>
    <p class="section-title">Die wichtigsten Meldungen</p></div>
  <div class="prio-list">
    {% for h in top_priorities[:3] %}
    <article class="prio-card{% if loop.first %} lead{% endif %}">
      <div class="prio-top">
        <span class="rel-badge r{{ h.relevance }}">{{ h.relevance }}/5 &middot; {{ h.relevance_label }}</span>
      </div>
      <h3><a href="{{ h.url }}" target="_blank" rel="noopener">{{ h.de_title }}</a></h3>
      <p class="prio-meta"><b>{{ h.operator or h.source_label }}</b><span class="sep"></span>{{ h.region }}{% if h.date %}<span class="sep"></span>{{ h.date }}{% endif %}</p>
      {% if h.summary %}<p class="prio-summary">{{ h.summary }}</p>{% endif %}
      <a class="source-link" href="{{ h.url }}" target="_blank" rel="noopener">Quelle: {{ h.source_label }} &nearr;</a>
    </article>
    {% endfor %}
  </div>
</section>
{% endif %}

{% if briefing_html %}
<section class="section" id="bericht">
  <div class="section-head"><p class="section-title">Der Wochenbericht</p></div>
  <article class="briefing prose">{{ briefing_html | safe }}</article>
</section>
{% endif %}

{% if highlights %}
<section class="section" id="explorer">
  <div class="section-head"><p class="section-title">Alle Meldungen</p></div>
  <details class="evidence">
    <summary><span>Alle {{ highlights | length }} Meldungen durchsuchen</span><small>bei Bedarf öffnen</small></summary>
    <div class="evidence-body">
      <div class="filters">
        <input type="search" id="f-search" placeholder="Suchen: Operator, Thema, Stichwort …" aria-label="Suche">
        <select id="f-region" aria-label="Region"><option value="">Alle Regionen</option>{% for r in regions %}<option value="{{ r }}">{{ r }}</option>{% endfor %}</select>
        <select id="f-category" aria-label="Thema"><option value="">Alle Themen</option>{% for c in categories %}<option value="{{ c }}">{{ c }}</option>{% endfor %}</select>
        <select id="f-relevance" aria-label="Dringlichkeit"><option value="">Jede Dringlichkeit</option><option value="5">5/5 sofort</option><option value="4">ab 4/5</option><option value="3">ab 3/5</option></select>
        <select id="f-sort" aria-label="Sortierung"><option value="relevance">Dringlichste zuerst</option><option value="date">Neueste zuerst</option><option value="operator">Operator (A–Z)</option></select>
      </div>
      <div class="explorer" id="explorer-app">
        <div class="ex-list" id="ex-list" role="listbox" aria-label="Meldungsliste"></div>
        <div class="ex-detail" id="ex-detail"><p class="ex-detail-empty">Meldung links auswählen.</p></div>
      </div>
      <p class="ex-count" id="ex-count"></p>
      <script type="application/json" id="explorer-data">{{ explorer_json | safe }}</script>
    </div>
  </details>
</section>
{% endif %}

{% else %}
<section class="hero"><h1>Noch kein Bericht</h1></section>
{% endif %}
{% endblock %}
