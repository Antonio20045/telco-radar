<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}Telco Radar{% endblock %}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ prefix }}style.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><circle cx='50' cy='50' r='42' fill='%23e60000'/><circle cx='50' cy='50' r='26' fill='none' stroke='white' stroke-width='6'/><circle cx='50' cy='50' r='8' fill='white'/></svg>">
</head>
<body>
  <header class="topbar">
    <div class="wrap topbar-inner">
      <a class="brand" href="{{ prefix }}index.html">
        <span class="brand-dot"></span>
        <span class="brand-name">Telco <em>Radar</em></span>
      </a>
      <nav class="nav">
        <a href="{{ prefix }}index.html" {% if active == 'dashboard' %}class="active"{% endif %}>Dashboard</a>
        <a href="{{ prefix }}archive.html" {% if active == 'archive' %}class="active"{% endif %}>Archiv</a>
        <a href="{{ prefix }}sources.html" {% if active == 'sources' %}class="active"{% endif %}>Quellen</a>
      </nav>
    </div>
  </header>
  <main>
    <div class="wrap">
      {% block content %}{% endblock %}
    </div>
  </main>
  <footer class="footer">
    <div class="wrap">
      Telco Radar · automatisiertes Competitive-Intelligence-Briefing · Quellen: Operator-Newsrooms & Telco-Fachpresse weltweit
    </div>
  </footer>
  {% block scripts %}{% endblock %}
</body>
</html>
