<!DOCTYPE html>
<html lang="de" data-theme="dark">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}Telco Radar{% endblock %}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ prefix }}style.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%230b0f16'/><circle cx='50' cy='50' r='30' fill='none' stroke='%23e60000' stroke-width='7'/><circle cx='50' cy='50' r='9' fill='%23e60000'/></svg>">
  <script>
    try { document.documentElement.dataset.theme = localStorage.getItem('tr-theme') || 'dark'; } catch (e) {}
  </script>
</head>
<body>
  <header class="topbar">
    <div class="wrap topbar-inner">
      <a class="brand" href="{{ prefix }}index.html">
        <span class="brand-mark"><span class="brand-ring"></span></span>
        <span class="brand-name">TELCO<em>RADAR</em></span>
      </a>
      <nav class="nav">
        <a href="{{ prefix }}index.html" {% if active == 'dashboard' %}class="active"{% endif %}>Bericht</a>
        <a href="{{ prefix }}archive.html" {% if active == 'archive' %}class="active"{% endif %}>Archiv</a>
        <a href="{{ prefix }}sources.html" {% if active == 'sources' %}class="active"{% endif %}>Quellen</a>
        <button class="theme-toggle" id="theme-toggle" title="Hell/Dunkel umschalten" aria-label="Farbschema umschalten">
          <span class="tt-dark">☾</span><span class="tt-light">☀</span>
        </button>
      </nav>
    </div>
  </header>
  {% block ticker %}{% endblock %}
  <main>
    <div class="wrap">
      {% block content %}{% endblock %}
    </div>
  </main>
  <footer class="footer">
    <div class="wrap footer-inner">
      <div>
        <strong>Telco Radar</strong> — automatisches Wettbewerbs-Monitoring der Telekommunikationsbranche.
        Jede Woche werden die Presseseiten von {{ '59' }} Netzbetreibern weltweit und die internationale
        Fachpresse geprüft. Nur wirklich neue Meldungen werden bewertet und hier zusammengefasst.
      </div>
      <div class="footer-meta">Alle Angaben mit Link zur Originalquelle · intern</div>
    </div>
  </footer>
  <script src="{{ prefix }}app.js"></script>
</body>
</html>
