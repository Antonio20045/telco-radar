<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}Telco Radar{% endblock %}</title>
  <meta name="robots" content="noindex">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ prefix }}style.css">
  <link rel="icon" type="image/png" href="{{ prefix }}logo.png">
</head>
<body>
  <header class="topbar">
    <div class="wrap topbar-inner">
      <a class="brand" href="{{ prefix }}index.html" aria-label="Telco Radar">
        <img class="brand-logo" src="{{ prefix }}logo.png" alt="Vodafone" width="30" height="30">
        <span class="brand-name">Telco<em>Radar</em></span>
      </a>
      <nav class="nav">
        <a href="{{ prefix }}index.html" {% if active == 'dashboard' %}class="active"{% endif %}>Bericht</a>
        <a href="{{ prefix }}differenzierung.html" {% if active == 'differenzierung' %}class="active"{% endif %}>Differenzierung</a>
        <a href="{{ prefix }}wettbewerber.html" {% if active == 'wettbewerber' %}class="active"{% endif %}>Wettbewerber</a>
        <a href="{{ prefix }}protokoll.html" {% if active == 'protokoll' %}class="active"{% endif %}>Protokoll</a>
        <a href="{{ prefix }}archive.html" {% if active == 'archive' %}class="active"{% endif %}>Archiv</a>
        <a href="{{ prefix }}sources.html" {% if active == 'sources' %}class="active"{% endif %}>Quellen</a>
      </nav>
    </div>
  </header>
  <main>
    <div class="wrap">
      {% block content %}{% endblock %}
    </div>
  </main>
  <footer class="footer">
    <div class="wrap footer-inner">
      <div style="max-width:640px">
        <b>Telco Radar</b> beobachtet jede Woche die Presse von {{ num_operators or '80' }} Netzbetreibern
        weltweit und die internationale Fachpresse. Nur wirklich neue Meldungen werden bewertet und hier
        zusammengefasst. Jede Aussage verlinkt auf die Originalquelle.
      </div>
      <div class="footer-meta">Intern &middot; für Vodafone</div>
    </div>
  </footer>
  <script src="{{ prefix }}app.js"></script>
</body>
</html>
