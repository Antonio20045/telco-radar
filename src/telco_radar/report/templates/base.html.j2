<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}Vodafone Insights{% endblock %}</title>
  <meta name="robots" content="noindex">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ prefix }}style.css">
  <link rel="icon" type="image/png" href="{{ prefix }}logo.png">
</head>
<body>
  <header class="topbar">
    <div class="wrap topbar-inner">
      <a class="brand" href="{{ prefix }}index.html" aria-label="Vodafone Insights">
        <img class="brand-logo" src="{{ prefix }}logo.png" alt="Vodafone" width="26" height="26">
        <span class="brand-name">Vodafone<em>Insights</em></span>
      </a>
      <nav class="usecases" aria-label="Anwendungsfälle">
        <a class="uc active" href="{{ prefix }}index.html">Marktrecherche</a>
        <span class="uc soon" title="folgt">weitere folgen</span>
      </nav>
    </div>
    <div class="subbar">
      <nav class="wrap subnav" aria-label="Marktrecherche">
        <a href="{{ prefix }}index.html" {% if active=='uebersicht' %}class="on"{% endif %}>Übersicht</a>
        <a href="{{ prefix }}bericht.html" {% if active=='bericht' %}class="on"{% endif %}>Bericht</a>
        <a href="{{ prefix }}differenzierung.html" {% if active=='differenzierung' %}class="on"{% endif %}>Differenzierung</a>
        <a href="{{ prefix }}wettbewerber.html" {% if active=='wettbewerber' %}class="on"{% endif %}>Wettbewerber</a>
        <a href="{{ prefix }}protokoll.html" {% if active=='protokoll' %}class="on"{% endif %}>Protokoll</a>
        <a href="{{ prefix }}archive.html" {% if active=='archive' %}class="on"{% endif %}>Archiv</a>
        <a href="{{ prefix }}sources.html" {% if active=='sources' %}class="on"{% endif %}>Quellen</a>
      </nav>
    </div>
  </header>
  <main>
    <div class="wrap">
      {% block content %}{% endblock %}
    </div>
  </main>
  <footer class="foot">
    <div class="wrap foot-inner">
      <span>Vodafone Insights &middot; Marktrecherche</span>
      <span class="foot-meta">Intern &middot; automatisch aktualisiert</span>
    </div>
  </footer>
  <script src="{{ prefix }}app.js"></script>
</body>
</html>
