{% extends "base.html.j2" %}
{% set active = 'sources' %}
{% block title %}Telco Radar - Quellen{% endblock %}
{% set kmap = {'newsroom':'Newsroom','rss':'RSS','news_search':'Nachrichten-Suche','official':'Newsroom'} %}
{% block content %}
<section class="hero">
  <p class="eyebrow">Was der Radar beobachtet</p>
  <h1>Überwachte Quellen</h1>
  <p class="hero-sub">Die Basis ist die internationale und deutsche Telco-Fachpresse (unten) - jeder
  Artikel stammt direkt von einem Fachmedium. Meldungen werden den Betreibern über Namensnennung
  zugeordnet. Der Newsroom-Link dient als offizielle Referenz. Alles verlinkt und nachprüfbar.</p>
</section>

{% for region, ops in by_region.items() %}
<section class="source-region">
  <h2>{{ region }} <span class="count-badge">{{ ops | length }} Betreiber</span></h2>
  <div class="source-grid">
    {% for op in ops %}
    <div class="source-card">
      <div class="source-head">
        <h3>{{ op.name }}</h3>
        {% if op.country %}<span class="chip">{{ op.country }}</span>{% endif %}
      </div>
      <ul class="source-links">
        {% for s in op.sources %}
        <li>
          <span class="kbadge">{{ kmap.get(s.kind, s.kind) }}</span>
          {% if s.kind == 'news_search' %}
          <a href="https://news.google.com/search?q=&quot;{{ op.name | urlencode }}&quot;" target="_blank" rel="noopener">Aktuelle Meldungen zu {{ op.name }} &nearr;</a>
          {% else %}
          <a href="{{ s.url }}" target="_blank" rel="noopener">{{ s.url | domain }} &nearr;</a>
          {% endif %}
        </li>
        {% endfor %}
      </ul>
    </div>
    {% endfor %}
  </div>
</section>
{% endfor %}

<section class="source-region">
  <h2>Telco-Fachpresse <span class="count-badge">{{ news_sources | length }} Feeds</span></h2>
  <div class="source-grid">
    {% for s in news_sources %}
    <div class="source-card">
      <div class="source-head"><h3>{{ s.name }}</h3><span class="chip">RSS</span></div>
      <ul class="source-links">
        <li><span class="kbadge">Fachpresse</span>
        <a href="{{ s.url }}" target="_blank" rel="noopener">{{ s.url | domain }} &nearr;</a></li>
      </ul>
    </div>
    {% endfor %}
  </div>
</section>
{% endblock %}
