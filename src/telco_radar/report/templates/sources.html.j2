{% extends "base.html.j2" %}
{% set active = 'sources' %}
{% block title %}Telco Radar - Quellen{% endblock %}
{% set kmap = {'rss':'Feed','json_api':'Feed (API)','newsroom':'Newsroom','newsroom_js':'Newsroom','official':'Referenz'} %}
{% block content %}
<section class="page-hero">
  <div class="page-hero-row">
    <div>
      <p class="page-kicker">Transparenz</p>
      <h1>Überwachte Quellen</h1>
    </div>
  </div>
  <p class="page-lead">Primärquelle jedes Betreibers ist <strong>seine eigene offizielle Presseseite</strong> -
  per Feed (RSS/JSON), statischem Newsroom oder Headless-Render direkt vom Unternehmen. Kein Dritt-Medium wird
  als Quelle eines Betreibers ausgegeben. Die Telco-Fachpresse (unten) ist eine separate, klar gekennzeichnete
  <strong>zweite Ebene</strong>. Alles verlinkt und nachprüfbar.</p>
</section>

{% for region, ops in by_region.items() %}
<section class="source-region">
  <h2>{{ region }} <span class="count-badge">{{ ops | length }} Betreiber</span></h2>
  <div class="source-grid">
    {% for op in ops %}
    <div class="source-card">
      <div class="source-head">
        <h3>{{ op.name }}</h3>
        {% if op.country %}<span class="chip">{{ op.country }}</span>{% endif %}
      </div>
      {% if op.website %}<p class="source-domain">{{ op.website }}</p>{% endif %}
      <ul class="source-links">
        {% for s in op.sources %}
        <li>
          <span class="kbadge">{{ kmap.get(s.kind, s.kind) }}</span>
          <a href="{{ s.url }}" target="_blank" rel="noopener">{{ s.url | domain }} &nearr;</a>
          {% if s.kind == 'official' %}<span class="src-note" title="{{ s.plan }}">offizielle Referenz - Auto-Signal vorerst über Fachpresse (Plan hinterlegt)</span>{% endif %}
        </li>
        {% endfor %}
      </ul>
    </div>
    {% endfor %}
  </div>
</section>
{% endfor %}

<section class="source-region">
  <h2>Telco-Fachpresse <span class="count-badge">zweite Ebene · {{ news_sources | length }} Feeds</span></h2>
  <p class="hero-sub">Spezialisierte Telekom-Fachmedien. Dient als ergänzende Signal-Ebene und zur Abdeckung
  bot-geblockter Betreiber - Meldungen werden über Namensnennung dem jeweiligen Betreiber zugeordnet, sind aber
  immer als Fachpresse gekennzeichnet, nie als offizielle Quelle des Betreibers.</p>
  <div class="source-grid">
    {% for s in news_sources %}
    <div class="source-card">
      <div class="source-head"><h3>{{ s.name }}</h3><span class="chip">RSS</span></div>
      <ul class="source-links">
        <li><span class="kbadge">Fachpresse</span>
        <a href="{{ s.url }}" target="_blank" rel="noopener">{{ s.url | domain }} &nearr;</a></li>
      </ul>
    </div>
    {% endfor %}
  </div>
</section>
{% endblock %}
