{% extends "base.html.j2" %}
{% set active = 'differenzierung' %}
{% block title %}Marktrecherche · Differenzierung{% endblock %}
{% block content %}

<section class="dz-hero">
  <div class="dz-hero-row">
    <h1>Differenzierung</h1>
    {% if date_de %}<span class="dz-date">Stand {{ date_de }}</span>{% endif %}
  </div>
  <p class="dz-lead">Wie sich Wettbewerber weltweit <b>jenseits des Preises</b> abheben – über
  eingebundene Dienste, Garantien, KI, Perks und Ökosysteme. Als Inspiration für Vodafone,
  Move für Move mit Quelle. Netz-, 5G- und Broadband-Ausbau bleiben bewusst außen vor.</p>
</section>

{% if diff.active %}
{% for t in diff.active %}
<section class="dz-theme" style="--c:{{ t.color }}">
  <div class="dz-theme-head">
    <h2>{{ t.label }}</h2>
    <span class="dz-count">{{ t.n }} {{ 'Move' if t.n == 1 else 'Moves' }}</span>
  </div>
  <p class="dz-blurb">{{ t.blurb }}</p>
  <div class="dz-context">
    <p class="dz-vorbilder"><span>Wer macht’s vor</span>{% for v in t.vorbilder %}<b>{{ v.name }}</b>{% if not loop.last %}, {% endif %}{% endfor %}</p>
    <p class="dz-impuls"><span>Für Vodafone</span>{{ t.impuls }}</p>
  </div>
  <ul class="dz-moves">
    {% for m in t.moves[:8] %}
    <li class="dz-move">
      <a class="dz-move-title" href="{{ m.url }}" target="_blank" rel="noopener">{{ m.de_title }}</a>
      {% if m.why %}<p class="dz-move-why">{{ m.why }}</p>{% endif %}
      <p class="dz-move-meta"><b>{{ m.op }}</b>{% if m.region %} · {{ m.region }}{% endif %}{% if m.date %} · {{ m.date | date_de }}{% endif %} · <a href="{{ m.url }}" target="_blank" rel="noopener">{{ m.domain }} &nearr;</a></p>
    </li>
    {% endfor %}
  </ul>
  {% if t.moves|length > 8 %}<p class="dz-more">+ {{ t.moves|length - 8 }} weitere in dieser Kategorie</p>{% endif %}
</section>
{% endfor %}
{% endif %}

{% if diff.quiet %}
<section class="dz-quiet">
  <h2 class="dz-quiet-head">Weitere Differenzierungs-Felder</h2>
  <div class="dz-quiet-grid">
    {% for t in diff.quiet %}
    <div class="dz-q" style="--c:{{ t.color }}">
      <h3>{{ t.label }}</h3>
      <p class="dz-q-blurb">{{ t.blurb }}</p>
      <p class="dz-q-line"><span>Vorbild</span>{{ t.vorbilder[0].name }}</p>
      <p class="dz-q-line"><span>Impuls</span>{{ t.impuls }}</p>
    </div>
    {% endfor %}
  </div>
</section>
{% endif %}

{% if not diff.active and not diff.quiet %}
<section class="dz-theme"><p class="muted-note">Noch keine Differenzierungs-Moves erfasst – sie entstehen beim nächsten Lauf der Pipeline.</p></section>
{% endif %}

<p class="dz-foot">Automatisch aus den Pressestellen von {{ num_operators or '80+' }} Netzbetreibern und der Telko-Fachpresse zusammengestellt – nur Differenzierungs-Moves, ohne reine Preis-, Netz- und B2B-Meldungen. Relevante Moves bleiben über Wochen erhalten.</p>
{% endblock %}
