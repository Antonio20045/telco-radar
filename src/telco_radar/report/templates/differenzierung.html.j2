{% extends "base.html.j2" %}
{% set active = 'differenzierung' %}
{% block title %}Marktrecherche · Differenzierung{% endblock %}
{% block content %}

<section class="dz-hero">
  <div class="dz-hero-row">
    <h1>Differenzierung</h1>
    {% if date_de %}<span class="dz-date">Stand {{ date_de }}</span>{% endif %}
  </div>
  <p class="dz-lead">Wie sich Wettbewerber weltweit <b>jenseits des Preises</b> abheben – eingebundene
  Dienste, Garantien, KI, Perks, Ökosysteme. Jeder Eintrag ist ein echter, belegter Move mit Quelle;
  ein wöchentlicher Web-Sweep hält die Sammlung aktuell. Netz-, 5G- und Broadband-Ausbau bleiben außen vor.</p>
  {% if diff_stats %}
  <div class="dz-status">
    <span><b>{{ diff_stats.total }}</b> belegte Moves</span><span class="dz-sep"></span>
    <span><b>{{ diff_stats.themes_active }}</b>/{{ diff_stats.themes_total }} Kategorien aktiv</span><span class="dz-sep"></span>
    {% if diff_stats.new %}<span><b>{{ diff_stats.new }}</b> neu</span><span class="dz-sep"></span>{% endif %}
    <span>zuletzt aktualisiert {{ diff_stats.updated_de }}</span>
  </div>
  {% endif %}
</section>

{% for t in diff_themes %}
<article class="dz-card" style="--c:{{ t.color }}">
  <div class="dz-card-head">
    <h2>{{ t.label }}</h2>
    {% if t.n %}<span class="dz-count">{{ t.n }} {{ 'Move' if t.n == 1 else 'Moves' }}</span>{% endif %}
  </div>
  {% if t.entries %}
  <ul class="dz-moves">
    {% for e in t.entries %}
    <li class="dz-move">
      <div class="dz-move-h">
        <a class="dz-move-title" href="{{ e.url }}" target="_blank" rel="noopener"><b>{{ e.operator }}</b> — {{ e.what }}</a>
        {% if e.neu %}<span class="dz-new">neu</span>{% endif %}
      </div>
      {% if e.why %}<p class="dz-move-why">{{ e.why }}</p>{% endif %}
      <p class="dz-move-meta">{% if e.region %}{{ e.region }} · {% endif %}{% if e.date %}{{ e.date }} · {% endif %}<a href="{{ e.url }}" target="_blank" rel="noopener">{{ e.source }} &nearr;</a>{% if e.verified_de %} · geprüft {{ e.verified_de }}{% endif %}</p>
    </li>
    {% endfor %}
  </ul>
  {% else %}
  <p class="dz-empty">Aktuell kein belegter Move erfasst – der wöchentliche Sweep beobachtet diese Kategorie weiter.</p>
  {% endif %}
</article>
{% endfor %}

<p class="dz-foot">Zwei Quellen speisen diese Seite: der wöchentliche Presse-Crawl der beobachteten Netzbetreiber
und ein rotierender Web-Sweep (Brave Search + KI-Prüfung), der gezielt nach Differenzierung jenseits des Preises
sucht. Jeder Eintrag trägt Quelle und Prüfdatum; Moves ohne belegbare Quelle werden nicht aufgenommen.</p>
{% endblock %}
